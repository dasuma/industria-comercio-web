# GitHub Packages (para @biaenergy/ui)
# Generar un Personal Access Token con scope read:packages
# https://github.com/settings/tokens
NPM_TOKEN=

# Blob storage (PDF upload)
NEXT_PUBLIC_BLOB_URL=https://blitz-blob.azurewebsites.net

# City service (municipality info / shield image)
NEXT_PUBLIC_CITY_URL=https://blitz-city.azurewebsites.net

# Municipality slug used in blob storage paths (e.g. nocaima)
NEXT_PUBLIC_CITY_NAME=
